{
  "compilerOptions": {
    "outDir": "public/js",
    "lib": [
      "es2015",
      "dom"
    ],
    "target": "es2015",
    "module": "es2015"
  },
  "include": ["src"],
  "strict": true,
  "noFallthroughCasesInSwitch": true,
  "noImplicitReturns": true,
  "noUnusedLocals": true,
  "noUnusedParameters": true
}
